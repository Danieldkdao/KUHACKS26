{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL", "GEMINI_API_KEY", "AVIATION_STACK_API_KEY", "OPEN_TRIP_MAP_API_KEY"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "type-check": {
      "dependsOn": ["^type-check"]
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:studio": {
      "cache": false
    },
    "db:auth": {
      "cache": false
    }
  }
}